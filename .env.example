# Application
APP_NAME=Spend Analyzer
APP_ENV=local
APP_VERSION=0.1.0
APP_PORT=8000

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=spend_analyzer
DB_USER=spend_user
DB_PASSWORD=change_me

# Identity Provider / Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Identity Provider / OIDC
OIDC_ISSUER_URL=http://identity-provider:8080/realms/spend-analyzer
OIDC_JWKS_URL=http://identity-provider:8080/realms/spend-analyzer/protocol/openid-connect/certs
OIDC_AUDIENCE=spend-analyzer-api
OIDC_CLIENT_ID=spend-analyzer-api

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Storage
UPLOAD_DIR=/app/uploads
STORAGE_TYPE=local